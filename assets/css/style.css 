/* ==========================
   THE RAGA JOURNAL
   Version 1.0
========================== */

:root{

--bg:#F7F4EE;
--surface:#FFFFFF;
--text:#1A1A1A;
--muted:#666;
--border:#E6E1D8;
--accent:#8B5E3C;

--container:1400px;

--radius:16px;

}

*{
margin:0;
padding:0;
box-sizing:border-box;
}

html{

scroll-behavior:smooth;

}

body{

background:var(--bg);

color:var(--text);

font-family:Inter,sans-serif;

line-height:1.7;

-webkit-font-smoothing:antialiased;

}

img{

display:block;

max-width:100%;

height:auto;

}

a{

color:inherit;

text-decoration:none;

}

.header{

position:sticky;

top:0;

background:rgba(247,244,238,.95);

backdrop-filter:blur(12px);

border-bottom:1px solid var(--border);

z-index:1000;

}

.topbar{

max-width:var(--container);

margin:auto;

padding:18px 24px;

display:flex;

align-items:center;

justify-content:space-between;

gap:20px;

}

.logo{

display:flex;

align-items:center;

gap:16px;

}

.logo img{

width:58px;

height:58px;

border-radius:50%;

}

.logo h1{

font-family:"Cormorant Garamond",serif;

font-size:2rem;

font-weight:700;

}

.logo p{

font-size:.85rem;

color:var(--muted);

}

.menu-btn,
.search-btn{

background:none;

border:none;

font-size:1.3rem;

cursor:pointer;

}

nav{

display:flex;

justify-content:center;

gap:32px;

padding:14px;

border-top:1px solid var(--border);

border-bottom:1px solid var(--border);

background:white;

overflow-x:auto;

}

nav::-webkit-scrollbar{

display:none;

}

nav a{

font-size:.95rem;

font-weight:600;

white-space:nowrap;

transition:.25s;

}

nav a:hover{

color:var(--accent);

}

main{

max-width:var(--container);

margin:auto;

padding:50px 24px;

}

.hero{

display:grid;

grid-template-columns:1.1fr .9fr;

gap:50px;

align-items:center;

margin-bottom:80px;

}

.tag{

display:inline-block;

background:#EFE7DD;

color:var(--accent);

padding:6px 12px;

border-radius:100px;

font-size:.8rem;

font-weight:700;

margin-bottom:18px;

}

.hero h2{

font-family:"Cormorant Garamond",serif;

font-size:clamp(2.5rem,5vw,4.8rem);

line-height:1.05;

margin-bottom:20px;

}

.hero p{

font-size:1.1rem;

max-width:600px;

color:var(--muted);

margin-bottom:30px;

}

.button{

display:inline-flex;

align-items:center;

padding:14px 26px;

background:var(--accent);

color:white;

border-radius:999px;

transition:.3s;

}

.button:hover{

transform:translateY(-3px);

}

.hero-image img{

border-radius:22px;

box-shadow:0 15px 40px rgba(0,0,0,.12);

}

.articles h3{

font-family:"Cormorant Garamond",serif;

font-size:2.3rem;

margin-bottom:28px;

}

.article-grid{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(300px,1fr));

gap:24px;

}

article{

background:white;

padding:28px;

border-radius:18px;

border:1px solid var(--border);

transition:.3s;

cursor:pointer;

}

article:hover{

transform:translateY(-8px);

box-shadow:0 12px 30px rgba(0,0,0,.08);

}

article h4{

font-family:"Cormorant Garamond",serif;

font-size:1.7rem;

margin-bottom:12px;

}

article p{

color:var(--muted);

}

footer{

margin-top:90px;

padding:40px;

text-align:center;

border-top:1px solid var(--border);

color:var(--muted);

}

/* Tablet */

@media(max-width:1024px){

.hero{

grid-template-columns:1fr;

}

}

/* Mobile */

@media(max-width:768px){

.logo h1{

font-size:1.5rem;

}

.hero{

gap:30px;

}

main{

padding:30px 18px;

}

nav{

justify-content:flex-start;

padding-inline:20px;

}

.hero h2{

font-size:2.4rem;

}

.article-grid{

grid-template-columns:1fr;

}

}

/* Small phones */

@media(max-width:420px){

.logo img{

width:46px;

height:46px;

}

.logo h1{

font-size:1.25rem;

}

.hero h2{

font-size:2rem;

}

.button{

width:100%;

justify-content:center;

}

}